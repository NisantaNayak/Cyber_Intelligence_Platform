{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@prisma/client": ["node_modules/@prisma/client"],
      "@prisma/client/*": ["node_modules/@prisma/client/*"]
    },
    "outDir": "dist"
  },
  "include": ["src/**/*.ts"]
}
